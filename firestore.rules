rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isUserEditableKyc(userId) {
      return isOwner(userId)
        && (!('uid' in request.resource.data) || request.resource.data.uid == userId)
        && request.resource.data.status in ['inProgress', 'submitted'];
    }

    match /adminAssets/{document=**} {
      allow read, write: if isAdmin();
    }

    match /cryptoPaymentOptions/{document=**} {
      allow read, write: if isAdmin();
    }

    match /kycProfiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isUserEditableKyc(userId);
      allow delete: if isAdmin();
    }

    match /purchaseOrders/{orderId} {
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
  }
}
