{
  "name": "brickclub-functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only auth,functions,firestore,storage",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "claim:admin": "node scripts/set-admin-claim.cjs",
    "lint": "eslint --ext .js,.ts src"
  },
  "dependencies": {
    "@google-cloud/translate": "^8.5.1",
    "@google-cloud/vision": "^5.3.7",
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^7.0.0",
    "nodemailer": "^7.0.10"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.4",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3"
  }
}
